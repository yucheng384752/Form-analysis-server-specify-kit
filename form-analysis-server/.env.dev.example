# Development environment template. Copy to .env.dev locally and fill real secrets.
ENVIRONMENT=development
AUTH_MODE=api_key
ALLOW_AUTH_OFF=false
SECRET_KEY=replace-with-at-least-32-random-characters
ADMIN_API_KEY=replace-with-local-admin-api-key
DEFAULT_TENANT_API_KEY=replace-with-local-tenant-api-key
DATABASE_URL=sqlite+aiosqlite:///./data/dev.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

