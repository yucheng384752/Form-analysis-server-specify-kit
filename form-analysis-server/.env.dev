# ============================================================================
# Development Environment Configuration (.env.dev)
# ============================================================================
# 開發環境專用，使用 180xx ports
# 搭配 docker-compose.yml (development target) 使用
# ============================================================================

# Database Configuration (Development)
POSTGRES_USER=app
POSTGRES_PASSWORD=dev-change-me-strong
POSTGRES_DB=form_analysis_dev_db
POSTGRES_PORT=18001

# Database URL for docker-compose runtime
DATABASE_URL=postgresql+psycopg://app:dev-change-me-strong@db:5432/form_analysis_dev_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
HOST_API_PORT=18002
MAX_UPLOAD_SIZE_MB=10
UPLOAD_TEMP_DIR=./uploads

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:18003,http://localhost:5173,http://localhost:3000,http://localhost:8080

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json
DEBUG=true
RELOAD=true

# Frontend Configuration
FRONTEND_PORT=18003
VITE_API_URL=http://localhost:18002
VITE_MAX_FILE_SIZE=10485760
VITE_ENABLE_CSV_EDIT=true

# Optional: set when AUTH_MODE=api_key
#VITE_API_KEY=replace-with-dev-tenant-api-key
#VITE_API_KEY_HEADER=X-API-Key

# External Analytics (host paths for docker bind mounts)
SEPTEMBER_V2_HOST_PATH=C:/Users/yucheng/Desktop/september_v2
ANALYTICAL_FOUR_HOST_PATH=C:/Users/yucheng/Desktop/Analytical/Analytical-Four
PDF_SERVER_URL=http://192.168.178.151:8000

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_dev_password
PGADMIN_PORT=18004

# Development Settings
DEV_MODE=true

# Security Settings
SECRET_KEY=dev-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Lightweight Auth (optional override)
#AUTH_MODE=api_key
#AUTH_API_KEY_HEADER=X-API-Key
#AUTH_PROTECT_PREFIXES=/api
#AUTH_EXEMPT_PATHS=/healthz,/docs,/redoc,/openapi.json,/api/auth/login

# Admin bootstrap (development)
ADMIN_API_KEYS=dev-admin-key-for-testing
ADMIN_API_KEY_HEADER=X-Admin-API-Key
